{
  "name": "evo-foundation-models-ai-development-workshop",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "compose": "docker-compose up -d",
    "scan:secrets": "secretlint \"**/*\"",
    "duplication:check": "jscpd ./src --threshold 3 --gitignore",
    "duplication:report": "jscpd ./src --reporters html,console --output ./reports/duplication --gitignore",
    "security:check": "yarn audit --json | grep -qE '\"severity\":\\s*\"(high|critical)\"' && exit 1 || exit 0",
    "security:report": "yarn audit --level high"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@types/uuid": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongoose": "^9.3.3",
    "openai": "^6.33.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jscpd/html-reporter": "^4.0.4",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.1",
    "@types/express": "^5.0.6",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "prettier": "^3.8.1",
    "secretlint": "^11.4.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "resolutions": {
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "flatted": "3.4.2"
  }
}
